{
  "name": "@pricoteka/app",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "generate:build-scripts": "tsc -p build/tsconfig.json",
    "validate:i18n": "pnpm generate:build-scripts && node build/dist/validate-i18n.js",
    "generate:routes": "tsr generate",
    "generate": "pnpm generate:routes",
    "prepare:checks": "concurrently \"pnpm validate:i18n\" \"pnpm generate:routes\"",
    "dev": "pnpm prepare:checks && vite",
    "typecheck": "pnpm prepare:checks && tsc -b",
    "build": "pnpm prepare:checks && tsc -b && vite build",
    "lint": "pnpm prepare:checks && oxlint .",
    "format": "pnpm prepare:checks && oxfmt --check .",
    "format:fix": "pnpm prepare:checks && oxfmt .",
    "preview": "vite preview",
    "test": "pnpm prepare:checks && vitest run",
    "test:watch": "pnpm prepare:checks && vitest",
    "test:ui": "pnpm prepare:checks && vitest --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@phosphor-icons/react": "^2.1.10",
    "@pricoteka/core": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-form-devtools": "^0.2.29",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.16"
  }
}
