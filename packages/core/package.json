{
  "name": "@pricoteka/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && rolldown src/index.ts --format=esm --file=dist/index.js",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
