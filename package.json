{
  "name": "pricoteka",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "generate:build-scripts": "tsc -p build/tsconfig.json",
    "generate:i18n": "pnpm generate:build-scripts && node build/dist/generate-i18n.js",
    "dev": "pnpm generate:i18n && vite",
    "typecheck": "pnpm generate:i18n && tsc -b",
    "build": "pnpm generate:i18n && tsc -b && vite build",
    "preview": "vite preview",
    "format": "pnpm generate:i18n && oxfmt --check .",
    "format:fix": "pnpm generate:i18n && oxfmt --write .",
    "lint": "pnpm generate:i18n && fallow audit --changed-since HEAD && oxlint",
    "lint:fix": "pnpm generate:i18n && oxlint --fix",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:review": "fallow review",
    "fallow:fix": "fallow fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "fallow": "^2.101.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
