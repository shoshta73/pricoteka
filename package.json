{
  "name": "pricoteka",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @pricoteka/api dev\" \"pnpm --filter @pricoteka/app dev\"",
    "app-dev": "pnpm --filter @pricoteka/app dev",
    "app-typecheck": "pnpm --filter @pricoteka/app typecheck",
    "app-build": "pnpm --filter @pricoteka/app build",
    "app-test": "pnpm --filter @pricoteka/app test",
    "app-lint": "pnpm --filter @pricoteka/app lint",
    "app-format": "pnpm --filter @pricoteka/app format",
    "website-dev": "pnpm --filter @pricoteka/website dev",
    "website-build": "pnpm --filter @pricoteka/website build",
    "test": "pnpm -r --if-present test",
    "test:ui": "pnpm --filter @pricoteka/app test:ui",
    "lint": "pnpm --filter @pricoteka/app prepare:checks && oxlint .",
    "lint:fix": "pnpm --filter @pricoteka/app prepare:checks && oxlint --fix .",
    "format": "pnpm --filter @pricoteka/app prepare:checks && oxfmt --check .",
    "format:fix": "pnpm --filter @pricoteka/app prepare:checks && oxfmt --write .",
    "fallow": "fallow",
    "fallow:changed": "fallow audit --changed-since HEAD",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:review": "fallow review",
    "fallow:fix": "fallow fix"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "fallow": "^2.101.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "rolldown": "^1.0.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.5.0"
}
